# Copier ce fichier vers `.env` à la racine du dépôt (même dossier que docker-compose.yml).
# Docker Compose charge automatiquement `.env`. Ne commitez jamais `.env`.
#
# Générer un secret JWT fort (ex. 64 caractères aléatoires) :
#   openssl rand -base64 48

# --- Base PostgreSQL (docker-compose) ---
POSTGRES_DB=archivage
POSTGRES_USER=archivage
# Mot de passe au premier démarrage uniquement : si vous changez cette valeur après coup
# alors que ./data/postgres existe déjà, PostgreSQL refusera la connexion (mot de passe figé
# dans le volume). Soit remettre l’ancien mot de passe, soit supprimer ./data/postgres
# (perte des données locales) puis relancer docker compose.
POSTGRES_PASSWORD=change-me-db-password

# --- JWT (obligatoire en production : pas de valeur par défaut faible déployée) ---
JWT_SECRET=change-me-generate-with-openssl-rand-base64-48

# --- Backend / OCR / CORS (optionnel) ---
OCR_WORKERS=2
CLAMAV_ENABLED=true
# Avec la passerelle HTTPS (docker-compose.https.yml), ajoutez l’URL utilisée par le navigateur, ex. :
# CORS_ALLOWED_ORIGINS=https://localhost,http://localhost:13100,http://localhost:5173
# Inclure https://localhost si vous utilisez docker-compose.https.yml (passerelle sur le port 443 ou HTTPS_GATEWAY_PORT).
CORS_ALLOWED_ORIGINS=https://localhost,http://localhost:5173,http://localhost:3000,http://localhost:13100

# Limite de débit auth (PRD : Bucket4j) — tentatives / fenêtre par adresse IP (login + refresh).
# AUTH_RATE_LIMIT_MAX=30
# AUTH_RATE_LIMIT_WINDOW_SECONDS=60

# --- Frontend Docker (build) ---
# HTTP direct : URL du backend vue par le navigateur.
# Passerelle HTTPS : laisser vide pour same-origin (/api via Nginx). Voir nginx/README-https.md
VITE_API_URL=http://localhost:8080
# Déconnexion après X minutes sans activité (0 = désactivé). Défaut côté app : 30 si non défini.
VITE_IDLE_TIMEOUT_MINUTES=30
FRONTEND_PUBLISHED_PORT=13100

# --- Passerelle HTTPS (optionnel, voir nginx/README-https.md) ---
# Démarrage : bash scripts/up-https.sh   ou   .\scripts\up-https.ps1
# HTTPS_GATEWAY_PORT=443
# Sur Windows si 443 est refusé sans admin : HTTPS_GATEWAY_PORT=8443
# Avec le profil HTTPS, CORS par défaut inclut https://localhost (docker-compose.https.yml) ;
# surchargez CORS_ALLOWED_ORIGINS dans .env si besoin (liste complète).

# --- Dossier surveillé (backend : import périodique depuis un répertoire) ---
# Créez ./data/watch-incoming sur l’hôte (ou adaptez le chemin). Sous-dossiers créés par l’app : processed/, failed/, duplicate/
APP_INGEST_WATCH_ENABLED=false
APP_INGEST_WATCH_DIRECTORY=./data/watch-incoming
APP_INGEST_WATCH_INTERVAL_MS=60000
APP_INGEST_WATCH_USER_ID=1
APP_INGEST_WATCH_DOCUMENT_TYPE_ID=1
APP_INGEST_WATCH_FOLDER_NUMBER=INBOX
APP_INGEST_WATCH_TITLE_PREFIX=Import automatique
APP_INGEST_WATCH_LANGUAGE=FRENCH
APP_INGEST_WATCH_CONFIDENTIALITY=INTERNAL
