# Copier ce fichier vers `.env` à la racine du dépôt (même dossier que docker-compose.yml).
# Docker Compose charge automatiquement `.env`. Ne commitez jamais `.env`.
#
# Générer un secret JWT fort (ex. 64 caractères aléatoires) :
#   openssl rand -base64 48

# --- Base PostgreSQL (docker-compose) ---
POSTGRES_DB=archivage
POSTGRES_USER=archivage
POSTGRES_PASSWORD=change-me-db-password

# --- JWT (obligatoire en production : pas de valeur par défaut faible déployée) ---
JWT_SECRET=change-me-generate-with-openssl-rand-base64-48

# --- Backend / OCR / CORS (optionnel) ---
OCR_WORKERS=2
CLAMAV_ENABLED=true
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:13100

# --- Frontend Docker (build) ---
VITE_API_URL=http://localhost:8080
FRONTEND_PUBLISHED_PORT=13100
